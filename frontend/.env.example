# Frontend needs NO API keys — translation (Groq) and voice (ElevenLabs) are
# proxied through the backend, so all keys stay server-side. See backend/.env.example.
#
# Optional: override backend / WebSocket URLs for a deployed setup.
# VITE_API_BASE=https://your-backend.example.com
# VITE_WS_URL=wss://your-backend.example.com/ws/dashboard
