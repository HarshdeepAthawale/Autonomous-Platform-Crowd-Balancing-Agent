# Backend to publish density readings to
BACKEND_URL=http://127.0.0.1:8000

# Demo path: true = synthetic worked-example (no camera), false = real YOLOv8
USE_SYNTHETIC=true

# Real YOLOv8 path
MODEL_PATH=yolov8n.pt
CONF=0.35
FRAME_STRIDE=3
RESIZE_WIDTH=640

# Smoothing / publishing
SMOOTHING_WINDOW=10
PUBLISH_INTERVAL_SEC=1.0

# Sources (JSON): platform_id -> webcam index ("0"/"1") or clip path
SOURCES={"A": "0", "B": "1"}

# Must match backend PLATFORM_CAPACITY for consistent density %
PLATFORM_CAPACITY={"A": 200, "B": 200}
