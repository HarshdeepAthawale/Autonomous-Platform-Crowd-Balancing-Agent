# Zone thresholds (density %)
GREEN_MAX=60
YELLOW_MAX=85

# Agent / safety
HOLD_MAX_MIN=10
GRACE_MIN=5
LOOP_PERIOD_SEC=20

# Privacy: auto-expire records this many minutes after a train departs
RETENTION_AFTER_DEPARTURE_MIN=60

# Per-platform capacity (JSON). count / capacity * 100 = density %
PLATFORM_CAPACITY={"A": 200, "B": 200}

# Reasoning + live translation (used for announcements AND UI/voice translation).
# LLM_PROVIDER: "groq" (free, Llama 3 70B) or "claude"
LLM_PROVIDER=groq
GROQ_API_KEY=
CLAUDE_API_KEY=

# Voice (TTS) — ElevenLabs, server-side. Put ONE key, or SEVERAL comma-separated
# to pool free-tier credits; the backend rotates to the next key when one is spent.
# e.g. ELEVENLABS_API_KEY=sk_key1,sk_key2,sk_key3
ELEVENLABS_API_KEY=
