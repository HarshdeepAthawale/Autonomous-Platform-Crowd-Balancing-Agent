# Zone thresholds (density %)
GREEN_MAX=60
YELLOW_MAX=85

# Agent / safety
HOLD_MAX_MIN=10
GRACE_MIN=5
LOOP_PERIOD_SEC=20

# Privacy: auto-expire records this many minutes after a train departs
RETENTION_AFTER_DEPARTURE_MIN=60

# Per-platform capacity (JSON). count / capacity * 100 = density %
PLATFORM_CAPACITY={"A": 200, "B": 200}

# Used in Phase 3 (leave blank for rule-only fallback)
CLAUDE_API_KEY=
