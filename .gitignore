# Secrets & env
.env
.env.*
!.env.example
*.key

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Node / frontend
node_modules/
dist/
build/
.vite/
*.local

# ML / CV — never commit weights or recorded media (privacy)
*.pt
*.onnx
*.mp4
*.avi
*.mov
*.jpg
*.jpeg
*.png
frames/
recordings/
# …but UI assets bundled with the frontend ARE committed
!frontend/public/*.png
!frontend/public/*.jpg

# Data store / logs (privacy: no captured data in VCS)
*.db
*.sqlite
*.sqlite3
data/
logs/
*.log

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
!docs/diagrams/*.png
!docs/screenshots/*.png
